BIGQUERY_PROJECT_ID=lean-841e5
COLLECTION_PATH=units/{unitId}/audit_logs
DATABASE=(default)
DATABASE_REGION=southamerica-east1
DATASET_ID=firestore_export
DATASET_LOCATION=southamerica-east1
EXCLUDE_OLD_DATA=yes
firebaseextensions.v1beta.function/location=southamerica-east1
LOG_LEVEL=debug
MAX_DISPATCHES_PER_SECOND=100
MAX_ENQUEUE_ATTEMPTS=3
TABLE_ID=audit_logs
TABLE_PARTITIONING=HOUR
TIME_PARTITIONING_FIELD= [B
TIME_PARTITIONING_FIELD_TYPE=omit
USE_NEW_SNAPSHOT_QUERY_SYNTAX=yes
VIEW_TYPE=view
WILDCARD_IDS=false