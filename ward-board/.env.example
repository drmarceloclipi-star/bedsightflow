# BedSight Flow — variáveis de ambiente (copie para .env.local)

# ── FCM Push Notifications (P2-04) ──────────────────────────────────────────
# Chave VAPID pública para Firebase Cloud Messaging (Web Push).
# Obtenha em: Firebase Console → Project Settings → Cloud Messaging
#             → Web Push certificates → Gerar par de chaves → copiar a chave pública.
VITE_FCM_VAPID_KEY=<sua_chave_VAPID_aqui>
