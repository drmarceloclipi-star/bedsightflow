rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    // Super Admin: platform-level (SaaS owner). Separate from institutional hierarchy.
    function isSuperAdmin() {
      return isAuthed() && ('superAdmin' in request.auth.token) && request.auth.token.superAdmin == true;
    }

    // Global Admin: institution-level. Administers the hospital client.
    function isGlobalAdmin() {
      // Claim-only. No email fallback. See docs/RBAC_CONTRACT.md.
      return isAuthed() && ('admin' in request.auth.token) && request.auth.token.admin == true;
    }

    // Either platform or institution admin
    function isAnyAdmin() {
      return isSuperAdmin() || isGlobalAdmin();
    }

    // Central authz: /users/{uid}/authz/authz
    // Structure: { units: { unitId: { role: 'editor'|'admin'|'viewer' } } }
    // No doc = no unit access. exists() is explicit and short-circuits before get().
    function hasAuthzDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/authz/authz);
    }

    function userAuthzDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/authz/authz);
    }

    function isUnitMember(unitId) {
      return isAuthed() && (
        isAnyAdmin() ||
        (hasAuthzDoc() &&
         unitId in userAuthzDoc().data.get('units', {}))
      );
    }

    function isUnitEditorOrAdmin(unitId) {
      return isAuthed() && (
        isAnyAdmin() ||
        (hasAuthzDoc() &&
         unitId in userAuthzDoc().data.get('units', {}) &&
         userAuthzDoc().data.units[unitId].role in ['editor', 'admin'])
      );
    }

    function isUnitAdmin(unitId) {
      return isAuthed() && (
        isAnyAdmin() ||
        (hasAuthzDoc() &&
         unitId in userAuthzDoc().data.get('units', {}) &&
         userAuthzDoc().data.units[unitId].role == 'admin')
      );
    }

    // ── authorized_users (global whitelist) ───────────────────
    // Platform concern — only Super Admin can write.
    // Global Admin can read (to see who has access).
    match /authorized_users/{userId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    // ── Units root doc ─────────────────────────────────────────
    // Creating/deleting institutions is a platform concern (Super Admin).
    // Global Admin can read all units and update within their institution.
    match /units/{unitId} {
      allow read: if isAuthed();
      allow create, delete: if isSuperAdmin();
      allow update: if isAnyAdmin();
    }

    // ── Beds ──────────────────────────────────────────────────
    match /units/{unitId}/beds/{bedId} {
      allow read: if isUnitMember(unitId);
      allow write: if isUnitEditorOrAdmin(unitId);
    }

    // ── Board Settings ────────────────────────────────────────
    match /units/{unitId}/settings/{doc} {
      allow read: if isUnitMember(unitId);
      allow write: if isUnitAdmin(unitId);
    }

    // ── Huddles ───────────────────────────────────────────────
    // Completion policy (P0): only global admin or super admin can set completionState = 'COMPLETED'.
    // Editors can create and update huddles in any other state.
    match /units/{unitId}/huddles/{huddleId} {
      allow read: if isUnitMember(unitId);
      allow create: if isUnitEditorOrAdmin(unitId) &&
        request.resource.data.completionState != 'COMPLETED';
      allow update: if isUnitEditorOrAdmin(unitId) && (
        request.resource.data.completionState != 'COMPLETED' ||
        isAnyAdmin()
      );
      allow delete: if isAnyAdmin();
    }

    // ── Audit Logs ────────────────────────────────────────────
    match /units/{unitId}/audit_logs/{logId} {
      allow read: if isUnitAdmin(unitId);
      allow write: if false;
    }

    // ── Unit Users / RBAC (legacy data — not used by rules) ───
    match /units/{unitId}/users/{uid} {
      allow read: if isUnitAdmin(unitId);
      allow write: if isUnitAdmin(unitId);
    }

    // ── Central authz ─────────────────────────────────────────
    match /users/{uid}/authz/{doc} {
      allow read: if isAuthed() && (request.auth.uid == uid || isAnyAdmin());
      allow write: if isAnyAdmin();
    }

    // ── Default lock ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
